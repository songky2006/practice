<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Kogene Biotech | Molecular Diagnostics for a Safer World</title>
  <meta name="description" content="Kogene Biotech is a molecular diagnostics company delivering reliable diagnostic solutions for human, animal, food, and environmental health." />
  <style>
    :root {
      --bg: #0f0f0f;
      --black: #000000;
      --white: #ffffff;
      --ghost: rgba(255,255,255,0.64);
      --muted: rgba(255,255,255,0.42);
      --border-12: rgba(255,255,255,0.12);
      --border-08: rgba(255,255,255,0.08);
      --border-06: rgba(255,255,255,0.06);
      --cyan: #00ffff;
      --blue: #0089ff;
      --cobalt: #0007cd;
      --radius: 4px;
      --max: 1180px;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: "Aptos", "Segoe UI", system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
      background:
        radial-gradient(circle at 20% 12%, rgba(0,255,255,0.09), transparent 28%),
        radial-gradient(circle at 85% 8%, rgba(0,7,205,0.28), transparent 32%),
        linear-gradient(180deg, #0f0f0f 0%, #070707 100%);
      color: var(--white);
      line-height: 1.5;
      overflow-x: hidden;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    .mono {
      font-family: "JetBrains Mono", "SFMono-Regular", Menlo, Consolas, monospace;
      letter-spacing: -0.02em;
    }

    .container {
      width: min(var(--max), calc(100% - 40px));
      margin: 0 auto;
    }

    .nav {
      position: sticky;
      top: 0;
      z-index: 50;
      backdrop-filter: blur(18px);
      background: rgba(15,15,15,0.78);
      border-bottom: 1px solid var(--border-06);
    }

    .nav-inner {
      min-height: 72px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
    }

    .logo {
      display: flex;
      align-items: center;
      gap: 14px;
      min-height: 44px;
      font-weight: 700;
      letter-spacing: -0.03em;
    }

    .logo-image {
      display: block;
      width: 146px;
      height: auto;
      object-fit: contain;
    }

    .logo-copy {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .logo-copy strong {
      font-size: 15px;
      font-weight: 700;
    }

    .logo-copy span {
      color: var(--muted);
      font-size: 12px;
      letter-spacing: 0.03em;
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 24px;
      color: var(--ghost);
      font-size: 14px;
      font-weight: 500;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .nav-links a:hover {
      color: var(--white);
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 44px;
      padding: 10px 22px;
      border-radius: var(--radius);
      font-size: 14px;
      font-weight: 700;
      transition: 0.2s ease;
      cursor: pointer;
    }

    .btn-primary {
      background: linear-gradient(180deg, #21a3ff 0%, #0b67d1 100%);
      color: var(--white);
      border: 1px solid rgba(255,255,255,0.14);
      box-shadow: 0 0 0 1px rgba(0,137,255,0.1) inset;
    }

    .btn-primary:hover {
      transform: translate(-1px, -1px);
      box-shadow: 4px 4px 0 rgba(0,255,255,0.14);
    }

    .btn-secondary {
      background: rgba(0,255,255,0.08);
      border: 1px solid rgba(0,150,255,0.9);
      color: var(--white);
    }

    .btn-secondary:hover {
      background: rgba(0,255,255,0.14);
    }

    .hero {
      position: relative;
      padding: 112px 0 84px;
      border-bottom: 1px solid var(--border-06);
    }

    .hero::after {
      content: "";
      position: absolute;
      inset: auto 0 0 0;
      height: 160px;
      background: linear-gradient(180deg, transparent, rgba(0,7,205,0.08));
      pointer-events: none;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 26px;
      padding: 8px 12px;
      border: 1px solid var(--border-12);
      color: var(--ghost);
      background: rgba(255,255,255,0.025);
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.12em;
    }

    .eyebrow-dot {
      width: 7px;
      height: 7px;
      background: var(--cyan);
      box-shadow: 0 0 16px rgba(0,255,255,0.7);
    }

    h1 {
      max-width: 920px;
      font-size: clamp(44px, 8vw, 86px);
      line-height: 0.9;
      font-weight: 700;
      letter-spacing: -0.07em;
    }

    .hero-copy {
      max-width: 720px;
      margin-top: 28px;
      color: var(--ghost);
      font-size: clamp(17px, 2vw, 21px);
      line-height: 1.45;
    }

    .hero-copy strong,
    .section-desc strong,
    .statement p strong,
    .timeline-copy strong,
    .cta p strong {
      color: var(--white);
      font-weight: 700;
    }

    .hero-actions {
      display: flex;
      gap: 14px;
      flex-wrap: wrap;
      margin-top: 36px;
    }

    .hero-panel {
      position: relative;
      margin-top: 72px;
      border: 1px solid var(--border-12);
      background:
        linear-gradient(135deg, rgba(255,255,255,0.045), rgba(255,255,255,0.012)),
        #000;
      box-shadow: 0 8px 32px rgba(0,0,0,0.5);
    }

    .panel-top {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 14px;
      padding: 14px 16px;
      border-bottom: 1px solid var(--border-08);
      color: var(--muted);
      font-size: 12px;
    }

    .panel-grid {
      display: grid;
      grid-template-columns: 1.2fr 0.8fr;
      gap: 1px;
      background: var(--border-06);
    }

    .panel-cell {
      background: #000;
      padding: 28px;
    }

    .diagnostic-map {
      min-height: 310px;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 14px;
    }

    .signal-card {
      border: 1px solid var(--border-08);
      padding: 18px;
      background:
        radial-gradient(circle at 20% 0%, rgba(0,255,255,0.12), transparent 45%),
        rgba(255,255,255,0.02);
    }

    .signal-card span {
      display: block;
      color: var(--cyan);
      margin-bottom: 18px;
      font-size: 12px;
    }

    .signal-card strong {
      display: block;
      font-size: 20px;
      font-weight: 700;
      letter-spacing: -0.04em;
      margin-bottom: 8px;
    }

    .signal-card p {
      color: var(--ghost);
      font-size: 14px;
    }

    .terminal {
      height: 100%;
      border-left: 1px solid var(--border-06);
      color: var(--ghost);
      font-size: 13px;
      line-height: 1.8;
      white-space: pre-wrap;
    }

    .terminal .cyan {
      color: var(--cyan);
    }

    .section {
      padding: 96px 0;
      border-bottom: 1px solid var(--border-06);
    }

    .section-header {
      display: grid;
      grid-template-columns: 0.85fr 1.15fr;
      gap: 42px;
      align-items: end;
      margin-bottom: 44px;
    }

    .section-label {
      color: var(--cyan);
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      margin-bottom: 18px;
    }

    h2 {
      font-size: clamp(34px, 5vw, 56px);
      line-height: 0.98;
      font-weight: 700;
      letter-spacing: -0.06em;
    }

    .section-desc {
      color: var(--ghost);
      font-size: 17px;
      max-width: 660px;
    }

    .grid-3 {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
    }

    .card {
      min-height: 260px;
      padding: 26px;
      background:
        radial-gradient(circle at 100% 0%, rgba(0,137,255,0.09), transparent 42%),
        #000;
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: var(--radius);
    }

    .card:hover {
      border-color: rgba(0,255,255,0.32);
    }

    .card .num {
      color: var(--muted);
      font-size: 12px;
      margin-bottom: 34px;
    }

    .card h3 {
      font-size: 24px;
      line-height: 1.1;
      font-weight: 700;
      letter-spacing: -0.04em;
      margin-bottom: 14px;
    }

    .card p {
      color: var(--ghost);
      font-size: 15px;
    }

    .split {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 18px;
      align-items: stretch;
    }

    .statement {
      padding: 34px;
      border: 1px solid var(--border-12);
      background:
        radial-gradient(circle at 10% 15%, rgba(0,255,255,0.10), transparent 36%),
        #000;
    }

    .statement h3 {
      font-size: clamp(28px, 4vw, 44px);
      line-height: 1;
      font-weight: 700;
      letter-spacing: -0.06em;
      margin-bottom: 22px;
    }

    .statement p {
      color: var(--ghost);
      font-size: 16px;
    }

    .metric-list {
      display: grid;
      gap: 14px;
    }

    .metric {
      padding: 22px;
      border: 1px solid var(--border-08);
      background: rgba(255,255,255,0.025);
    }

    .metric strong {
      display: block;
      color: var(--white);
      font-size: 22px;
      font-weight: 700;
      letter-spacing: -0.04em;
      margin-bottom: 6px;
    }

    .metric span {
      color: var(--ghost);
      font-size: 14px;
    }

    .timeline {
      display: grid;
      gap: 12px;
    }

    .timeline-item {
      display: grid;
      grid-template-columns: 150px 1fr;
      gap: 24px;
      padding: 22px 0;
      border-bottom: 1px solid var(--border-08);
    }

    .timeline-item:last-child {
      border-bottom: 0;
    }

    .timeline-year {
      color: var(--cyan);
      font-size: 13px;
    }

    .timeline-title {
      font-size: 22px;
      font-weight: 700;
      letter-spacing: -0.04em;
      margin-bottom: 8px;
    }

    .timeline-copy {
      color: var(--ghost);
      font-size: 15px;
      max-width: 760px;
    }

    .cta {
      padding: 104px 0;
      text-align: center;
      background:
        radial-gradient(circle at 50% 0%, rgba(0,255,255,0.12), transparent 36%),
        linear-gradient(180deg, transparent, rgba(255,255,255,0.035));
    }

    .cta h2 {
      margin: 0 auto;
      max-width: 820px;
    }

    .cta p {
      margin: 24px auto 0;
      max-width: 650px;
      color: var(--ghost);
      font-size: 17px;
    }

    .cta .hero-actions {
      justify-content: center;
    }

    footer {
      padding: 32px 0;
      border-top: 1px solid var(--border-06);
      color: var(--muted);
      font-size: 13px;
    }

    .footer-inner {
      display: flex;
      justify-content: space-between;
      gap: 18px;
      flex-wrap: wrap;
    }

    @media (max-width: 980px) {
      .nav-inner {
        align-items: flex-start;
        padding: 14px 0;
      }

      .nav-links {
        gap: 16px;
      }

      .panel-grid,
      .section-header,
      .grid-3,
      .split {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 860px) {
      .hero {
        padding-top: 82px;
      }

      .diagnostic-map {
        grid-template-columns: 1fr;
      }

      .timeline-item {
        grid-template-columns: 1fr;
        gap: 8px;
      }

      .panel-cell,
      .statement {
        padding: 22px;
      }

      .logo-copy {
        display: none;
      }
    }

    @media (max-width: 640px) {
      .container {
        width: min(var(--max), calc(100% - 24px));
      }

      .nav-inner,
      .nav-links,
      .hero-actions {
        flex-direction: column;
        align-items: stretch;
      }

      .nav-links {
        width: 100%;
      }

      .nav-links a {
        padding: 4px 0;
      }

      .btn {
        width: 100%;
      }
    }
  </style>
</head>
<body>
  <nav class="nav">
